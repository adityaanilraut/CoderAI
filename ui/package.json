{
  "name": "@coderai/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CoderAI Ink (TypeScript + React) terminal UI",
  "scripts": {
    "dev": "bun run --watch src/cli.tsx",
    "build": "bun build src/cli.tsx --target=node --outfile=dist/cli.js --format=esm --external=react --external=ink",
    "compile": "bun run scripts/compile.ts",
    "compile:all": "for t in bun-darwin-arm64 bun-darwin-x64 bun-linux-x64 bun-linux-arm64 bun-windows-x64; do BUN_TARGET=$t bun run scripts/compile.ts || exit 1; done",
    "typecheck": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "bin": {
    "coderai-ui": "dist/cli.js"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=18"
  }
}
