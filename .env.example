# CoderAI environment variables
# Copy to `.env` (gitignored) or export in your shell.
# Prefer `coderAI setup` / `coderAI config set` for interactive configuration.
# Keys in the environment override ~/.coderAI/config.json.

# ── Provider API keys (set at least one) ──────────────────────────────────
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GROQ_API_KEY=
# DEEPSEEK_API_KEY=
# GEMINI_API_KEY=

# Optional web-search backends (web_search tool)
# TAVILY_API_KEY=
# EXA_API_KEY=
# CODERAI_SEARCH_BACKEND=auto   # auto | tavily | exa | ddg | searxng

# ── Local inference ───────────────────────────────────────────────────────
# LMSTUDIO_ENDPOINT=http://localhost:1234/v1
# LMSTUDIO_MODEL=local-model
# OLLAMA_ENDPOINT=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── Core agent settings ───────────────────────────────────────────────────
# CODERAI_DEFAULT_MODEL=claude-sonnet-4-6
# CODERAI_TEMPERATURE=0.7
# CODERAI_MAX_TOKENS=8192
# CODERAI_REASONING_EFFORT=medium   # high | medium | low | none
# CODERAI_STREAMING=true
# CODERAI_CONTEXT_WINDOW=200000
# CODERAI_BUDGET_LIMIT=0            # USD per session; 0 = unlimited
# CODERAI_MAX_ITERATIONS=50
# CODERAI_MAX_TOOL_OUTPUT=50000
# CODERAI_LOG_LEVEL=WARNING
# CODERAI_PROJECT_INSTRUCTION_FILE=CODERAI.md

# ── Timeouts & concurrency ────────────────────────────────────────────────
# CODERAI_TOOL_TIMEOUT_SECONDS=120
# CODERAI_SUBPROCESS_TIMEOUT_SECONDS=60
# CODERAI_SUBAGENT_TIMEOUT_SECONDS=300
# CODERAI_MAX_CONCURRENT_MUTATING_SUBAGENTS=2
# CODERAI_MAX_BACKGROUND_JOBS=4
# CODERAI_MAX_BACKGROUND_PROCESSES=8
# CODERAI_TOOL_RETRY_MAX_ATTEMPTS=2
# CODERAI_TOOL_RETRY_BASE_DELAY=1.0

# ── Web / browser ─────────────────────────────────────────────────────────
# CODERAI_WEB_TOOLS_IN_MAIN=true
# CODERAI_SEARCH_CACHE_TTL=3600
# CODERAI_PAGE_CACHE_TTL=3600
# CODERAI_RATE_LIMIT_DELAY=0.5
# CODERAI_CONCURRENT_SEARCH=true
# CODERAI_BROWSER_HEADLESS=true
# CODERAI_BROWSER_TIMEOUT=30
# CODERAI_BROWSER_ALLOWED_DOMAINS=

# ── Skills ────────────────────────────────────────────────────────────────
# CODERAI_AUTO_DETECT_SKILLS=true
# CODERAI_SKILL_CONFIDENCE_THRESHOLD=0.5
# CODERAI_SKILL_TOP_N=3
# CODERAI_SKILLS_USE_HASNA=false    # optional @hasna/skills CLI integration

# ── TUI ───────────────────────────────────────────────────────────────────
# CODERAI_TUI_NOTIFICATIONS=true
# CODERAI_LOG_STDERR=0              # 1 = also log to stderr (can corrupt TUI)

# ── Escape hatches (security-sensitive — leave unset unless you mean it) ──
# CODERAI_TRUST_WORKSPACE=0         # 1 = trust every workspace (skips /trust)
# CODERAI_ALLOW_OUTSIDE_PROJECT=0   # 1 = allow FS tools outside project root
# CODERAI_ALLOW_LOCAL_URLS=0        # 1 = allow web tools to hit localhost (SSRF bypass)
